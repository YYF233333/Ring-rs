#!/bin/sh
#
# Pre-commit hook：格式检查 + clippy 警告检查。
# 安装：git config core.hooksPath .githooks
#
# 仅运行快速检查（fmt + clippy），不跑完整测试以保持提交流畅。
# 完整门禁（含测试）请在提交后手动运行：cargo check-all

set -e

echo "[pre-commit] Running cargo fmt check..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo ""
    echo "ERROR: Code formatting check failed."
    echo "Run 'cargo fmt --all' to fix, then re-commit."
    exit 1
fi

echo "[pre-commit] Running cargo clippy..."
cargo clippy --workspace --all-targets -- -D warnings
if [ $? -ne 0 ]; then
    echo ""
    echo "ERROR: Clippy found warnings/errors."
    echo "Run 'cargo clippy --workspace --all-targets --fix' to auto-fix, then re-commit."
    exit 1
fi

echo "[pre-commit] All checks passed."

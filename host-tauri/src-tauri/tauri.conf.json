{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ring Engine",
  "version": "0.1.0",
  "identifier": "com.ringengine.vnhost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": ".."
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": ".."
    }
  },
  "app": {
    "windows": [
      {
        "title": "Ring Engine",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}

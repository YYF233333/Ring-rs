{
    "git.ignoreLimitWarning": true,
    "files.exclude": {
        "**/*.rpyc": true,
        "**/*.rpa": true,
        "**/*.rpymc": true,
        "**/cache/": true
    },
    "rust-analyzer.check.command": "clippy",
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true
    },
    "[typescript][vue]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "editor.formatOnSave": true
}